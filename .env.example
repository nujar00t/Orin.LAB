# Orin.LAB — Environment Variables
# Copy this file to .env and fill in your keys

# ──────────────────────────────────────────
# AI PROVIDER — choose one: anthropic | deepinfra | openai
# ──────────────────────────────────────────
AI_PROVIDER=anthropic

# Option A: Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option B: DeepInfra (OpenAI-compatible, free tier available)
# AI_PROVIDER=deepinfra
DEEPINFRA_API_KEY=your_deepinfra_api_key_here
DEEPINFRA_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
DEEPINFRA_VISION_MODEL=meta-llama/Llama-3.2-90B-Vision-Instruct

# Option C: Custom OpenAI-compatible (OpenRouter, Together, Groq, etc.)
# AI_PROVIDER=openai
# OPENAI_API_KEY=your_key_here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=mistralai/mixtral-8x7b-instruct

# ──────────────────────────────────────────
# Telegram Bot (required)
# ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ──────────────────────────────────────────
# Solana (optional)
# ──────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WALLET_ADDRESS=your_wallet_address_here

# ──────────────────────────────────────────
# Twitter/X Auto Poster (optional)
# ──────────────────────────────────────────
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here

# ──────────────────────────────────────────
# Settings
# ──────────────────────────────────────────
LOG_LEVEL=INFO
SIGNAL_CONFIDENCE_THRESHOLD=70
SIGNAL_INTERVAL=300
AUTO_POST_ENABLED=false
